# CyberClaw 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env

# ==================== 模型配置 ====================

# 默认模型提供商 (可选：openai, anthropic, aliyun, tencent, z.ai, ollama, other)
DEFAULT_PROVIDER=openai

# 默认模型名称
DEFAULT_MODEL=

# ==================== OpenAI 兼容配置 ====================
# 适用于：OpenAI、阿里云、腾讯云、Z.AI 等兼容接口

# API Key (必填，除非使用 Ollama)
OPENAI_API_KEY=


# Base URL (可选，使用官方接口可留空或注释)
# OpenAI 官方：https://api.openai.com/v1
# 阿里云：https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云 coding: https://coding.dashscope.aliyuncs.com/v1
OPENAI_API_BASE=https://token-plan-cn.xiaomimimo.com/v1

# ==================== Anthropic 配置 ====================
# 仅在 DEFAULT_PROVIDER=anthropic 时使用

# API Key
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Base URL (可选，使用代理时配置)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==================== Ollama 配置 ====================
# 仅在 DEFAULT_PROVIDER=ollama 时使用

# Ollama 本地服务地址 (默认：http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
TAVILY_API_KEY=tvly-